# Puerto de escucha del servidor Express (por defecto 3000)
PORT=3000

# Nombre/ruta del archivo de base de datos SQLite3
DB_FILE=database.sqlite

# Credenciales del Administrador por defecto (se crean al iniciar si la BD está vacía)
ADMIN_USER=admin
ADMIN_PASS=admin123

# Secreto de firma digital HMAC-SHA256 para validación de licencias
# ¡IMPORTANTE!: En producción, cambie esta clave por un secreto de alta entropía.
# Debe coincidir con la constante 'SharedHmacSecret' configurada en el cliente C#.
LICENSE_SECRET=hexastrategy_vendemax_secret_key_default

# Credenciales de Mercado Pago para Checkout Pro
MP_PUBLIC_KEY=su_clave_publica_aqui
MP_ACCESS_TOKEN=su_token_de_acceso_aqui

